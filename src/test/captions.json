[
  {
    "start": 0.0,
    "end": 1.76,
    "text": "बजारमा हल्ला छ, कसले",
    "highlight": []
  },
  {
    "start": 1.84,
    "end": 3.68,
    "text": "कति छिटो पैसा बनायो।",
    "highlight": [
      "पैसा"
    ]
  },
  {
    "start": 3.73,
    "end": 5.04,
    "text": "तर म सधैँ 'ब्लु",
    "highlight": []
  },
  {
    "start": 5.08,
    "end": 6.4,
    "text": "चिप' स्टक रोज्छु।",
    "highlight": []
  },
  {
    "start": 6.44,
    "end": 9.28,
    "text": "दशकौँदेखि बलिया, विश्वासिलो कम्पनी।",
    "highlight": []
  },
  {
    "start": 9.32,
    "end": 11.03,
    "text": "रातारात दोब्बर हुँदैनन्, तर",
    "highlight": []
  },
  {
    "start": 11.11,
    "end": 12.79,
    "text": "डुब्ने सम्भावना पनि कमै",
    "highlight": []
  },
  {
    "start": 12.83,
    "end": 14.67,
    "text": "हुन्छ। यो सुरक्षित बाटो",
    "highlight": []
  },
  {
    "start": 14.69,
    "end": 15.67,
    "text": "हो, मलाई थाहा छ।",
    "highlight": []
  },
  {
    "start": 15.78,
    "end": 17.35,
    "text": "तर कहिलेकाहीँ, यो स्थिर",
    "highlight": []
  },
  {
    "start": 17.43,
    "end": 19.27,
    "text": "यात्रामा, म भीडको बीचमा",
    "highlight": []
  },
  {
    "start": 19.35,
    "end": 21.35,
    "text": "पनि एक्लो महसुस गर्छु।",
    "highlight": []
  },
  {
    "start": 21.43,
    "end": 23.34,
    "text": "सबैजना छिटो दौडिरहेका छन्,",
    "highlight": []
  },
  {
    "start": 23.39,
    "end": 24.78,
    "text": "म भने बिस्तारै तर",
    "highlight": []
  },
  {
    "start": 24.9,
    "end": 26.46,
    "text": "ढुक्कले हिँडिरहेको छु।",
    "highlight": []
  },
  {
    "start": 26.5,
    "end": 28.38,
    "text": "यो एकान्त सुरक्षामा कस्तो",
    "highlight": []
  },
  {
    "start": 28.41,
    "end": 29.1,
    "text": "अनुभूति हुन्छ?",
    "highlight": []
  }
]